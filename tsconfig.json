{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": [
      "ESNext"
    ],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,

    "declaration": true,
    "emitDeclarationOnly": true,

    "types": [
      "bun"
    ],

    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
  },
  "include": [
    "src",
    "__tests__"
  ],
}
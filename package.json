{
  "name": "cxx-draft-to-index",
  "version": "0.0.0",
  "type": "module",
  "license": "Apache-2.0",
  "imports": {
    "#std-index": {
      "types": "./output.d.ts",
      "default": "./dist/std-index.json"
    }
  },
  "scripts": {
    "extract": "bun run src/main.ts",
    "link-map": "bun run src/link-map.ts",
    "build": "bun run extract && bun build src/web/index.html --outdir=dist",
    "dev": "bun run src/server.ts --watch",
    "start": "bun run src/server.ts",
    "test": "bun test"
  },
  "devDependencies": {
    "@gytx/cppreference-index": "^0.1.17",
    "@types/bun": "^1.3.12",
    "@types/react-dom": "^19.2.3",
    "remeda": "^2.34.0"
  },
  "dependencies": {
    "dependency-graph": "^1.0.0",
    "immer": "^11.1.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  }
}